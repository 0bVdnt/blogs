---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import LorenzBackground from '../components/LorenzBackground.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import TorusKnotBackground from '../components/TorusKnotBackground.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404 — Page Not Found" description="This page doesn't exist." />
		<style>
			.error-container {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				min-height: 60vh;
				text-align: center;
				padding: 2rem 1rem;
			}

			.error-terminal {
				display: inline-block;
				text-align: left;
				max-width: 520px;
				width: 100%;
				border-radius: 12px;
				border: 1px solid var(--surface2);
				background: var(--crust);
				box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
				animation: fadeInUp 0.5s ease forwards;
			}

			.terminal-bar {
				display: flex;
				align-items: center;
				gap: 8px;
				padding: 12px 16px;
				background: var(--mantle);
				border-radius: 11px 11px 0 0;
				border-bottom: 1px solid var(--surface1);
			}

			.terminal-dot {
				width: 12px;
				height: 12px;
				border-radius: 50%;
				box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.4);
			}

			.terminal-dot.red { background: var(--red); }
			.terminal-dot.yellow { background: var(--yellow); }
			.terminal-dot.green { background: var(--green); }

			.terminal-title {
				flex: 1;
				text-align: center;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--overlay1);
				margin-right: 56px;
				font-weight: 600;
			}

			.terminal-body {
				padding: 2rem 2.5rem;
				font-family: "JetBrains Mono", monospace;
			}

			.error-code {
				font-size: 4em;
				font-weight: 800;
				margin: 0;
				background: linear-gradient(135deg, var(--red), var(--maroon), var(--peach));
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 4s ease infinite;
				line-height: 1;
			}

			.error-line {
				color: var(--subtext0);
				font-size: 0.85em;
				margin: 0.5em 0;
				line-height: 1.6;
			}

			.error-prompt {
				color: var(--green);
			}

			.error-string {
				color: var(--yellow);
			}

			.error-keyword {
				color: var(--mauve);
			}

			.home-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				margin-top: 1.5em;
				padding: 0.6em 1.4em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.85em;
				color: var(--base);
				background: var(--accent);
				border: none;
				border-radius: 8px;
				text-decoration: none;
				transition: all 0.2s ease;
				font-weight: 600;
			}

			.home-link:hover {
				background: var(--accent-hover);
				transform: translateY(-2px);
				box-shadow: 0 4px 16px var(--glow-color);
				text-decoration: none;
				color: var(--base);
			}

			@media (prefers-reduced-motion: reduce) {
				.error-terminal { animation: none; opacity: 1; }
				.error-code { animation: none; background-size: 100% 100%; }
			}
		</style>
	</head>

	<body>
		<ParticleBackground />
		<LorenzBackground />
		<TorusKnotBackground />
		<Header />
		<main id="main-content">
			<div class="error-container">
				<div class="error-terminal">
					<div class="terminal-bar">
						<span class="terminal-dot red"></span>
						<span class="terminal-dot yellow"></span>
						<span class="terminal-dot green"></span>
						<span class="terminal-title">~/blogs/404</span>
					</div>
					<div class="terminal-body">
						<p class="error-code">404</p>
						<p class="error-line"><span class="error-prompt">$</span> cat ./page</p>
						<p class="error-line"><span class="error-keyword">Error</span>: <span class="error-string">"Page not found"</span></p>
						<p class="error-line"><span class="error-prompt">$</span> <span class="error-string">The requested path does not exist.</span></p>
						<a href={base} class="home-link">← cd ~/blogs</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>