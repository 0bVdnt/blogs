---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import LorenzBackground from '../../components/LorenzBackground.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import TorusKnotBackground from '../../components/TorusKnotBackground.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const tags = new Set<string>();
	
	posts.forEach(post => {
		post.data.tags?.forEach(tag => tags.add(tag));
	});

	return Array.from(tags).map(tag => ({
		params: { tag },
		props: { tag },
	}));
}

interface Props {
	tag: string;
}

const { tag } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter(post => post.data.tags?.includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} — ${SITE_TITLE}`} description={`Posts tagged with "${tag}"`} />
		<style>
			body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			#main-content {
				flex: 1;
			}

			.page-container {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}


			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.82em;
				color: var(--subtext0);
				text-decoration: none;
				padding: 0.5em 0.9em;
				border-radius: 8px;
				border: 1px solid var(--surface0);
				border-bottom: 2px dashed var(--surface1);
				background: var(--card-bg);
				transition: all 0.2s ease;
				margin-bottom: 2em;
			}

			.back-link:hover {
				color: var(--accent);
				border-color: var(--accent);
				border-bottom: 2px solid var(--accent);
				background: var(--surface0);
				text-decoration: none;
			}

			.back-link svg {
				width: 16px;
				height: 16px;
				transition: transform 0.2s ease;
			}

			.back-link:hover svg {
				transform: translateX(-3px);
			}

			.page-header {
				text-align: center;
				margin-bottom: 2.5em;
				animation: fadeInUp 0.4s ease forwards;
			}

			.page-header .page-label {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.78em;
				color: var(--subtext0);
				background: var(--card-bg);
				padding: 0.35em 0.9em;
				border-radius: 6px;
				border: 1px solid var(--card-border);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				margin-bottom: 1em;
			}

			.page-label-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--blue);
			}

			.page-header h1 {
				font-size: 2.4em;
				margin: 0 0 0.3em;
				background: linear-gradient(135deg, var(--mauve), var(--blue), var(--lavender));
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 6s ease infinite;
			}

			.page-header h1 .tag-hash {
				color: var(--overlay1);
				font-weight: 400;
				-webkit-text-fill-color: var(--overlay1);
			}

			.post-count {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.85em;
				color: var(--subtext0);
				margin: 0;
			}

			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.post-card {
				animation: fadeInUp 0.4s ease forwards;
				opacity: 0;
			}

			.post-link {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				padding: 1.25rem 1.5rem;
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				text-decoration: none;
				transition: all 0.2s ease;
				position: relative;
				overflow: hidden;
			}

			.post-link::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 3px;
				background: var(--accent);
				transform: scaleY(0);
				transition: transform 0.2s ease;
			}

			.post-link:hover {
				background: var(--surface0);
				border-color: var(--surface1);
				text-decoration: none;
			}

			.post-link:hover::before {
				transform: scaleY(1);
			}

			.post-date {
				flex-shrink: 0;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--overlay1);
				min-width: 90px;
			}

			.post-content {
				flex: 1;
				min-width: 0;
			}

			.post-title {
				font-family: "JetBrains Mono", monospace;
				font-size: 1em;
				font-weight: 600;
				color: var(--text);
				margin: 0;
				line-height: 1.4;
				transition: color 0.2s ease;
			}

			.post-link:hover .post-title {
				color: var(--accent);
			}

			.post-description {
				font-size: 0.85em;
				color: var(--subtext0);
				margin: 0.35em 0 0;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.post-arrow {
				flex-shrink: 0;
				color: var(--overlay0);
				transition: all 0.2s ease;
			}

			.post-link:hover .post-arrow {
				color: var(--accent);
				transform: translateX(3px);
			}

			.empty-state {
				text-align: center;
				padding: 3rem;
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 12px;
			}

			.empty-state p {
				color: var(--subtext0);
				font-family: "JetBrains Mono", monospace;
				margin: 0;
			}

			@media (max-width: 600px) {
				.post-link {
					flex-direction: column;
					align-items: flex-start;
					gap: 0.5rem;
				}

				.post-date {
					min-width: auto;
				}

				.post-arrow {
					display: none;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.page-header,
				.post-card {
					animation: none;
					opacity: 1;
				}

				.post-link::before,
				.post-link,
				.post-arrow,
				.back-link svg {
					transition: none;
				}
			}
		</style>
	</head>
	<body>
		<ParticleBackground />
		<LorenzBackground />
		<TorusKnotBackground />
		<Header />
		<main id="main-content">
			<div class="page-container">
					<a href={`${base}tags/`} class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
						All tags
					</a>

				<header class="page-header">
					<span class="page-label">
						<span class="page-label-dot"></span>
						~/blogs/tags/{tag}
					</span>
					<h1><span class="tag-hash">#</span>{tag}</h1>
					<p class="post-count">{posts.length} {posts.length === 1 ? 'post' : 'posts'} with this tag</p>
					<hr style="margin-top: 1.5em;" />
				</header>

				{posts.length === 0 ? (
					<div class="empty-state">
						<p>No posts found with this tag.</p>
					</div>
				) : (
					<div class="posts-list">
						{posts.map((post, index) => (
							<article class="post-card" style={`animation-delay: ${index * 0.05}s`}>
								<a href={`${base}${post.id}/`} class="post-link">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<div class="post-content">
										<h2 class="post-title">{post.data.title}</h2>
										{post.data.description && (
											<p class="post-description">{post.data.description}</p>
										)}
									</div>
									<span class="post-arrow">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
									</span>
								</a>
							</article>
						))}
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>