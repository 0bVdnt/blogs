---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import LorenzBackground from '../../components/LorenzBackground.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import TorusKnotBackground from '../../components/TorusKnotBackground.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const posts = await getCollection('blog');

const tagCounts = new Map<string, number>();
posts.forEach(post => {
	post.data.tags?.forEach(tag => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

const sortedTags = Array.from(tagCounts.entries())
	.sort((a, b) => {
		if (b[1] !== a[1]) return b[1] - a[1];
		return a[0].localeCompare(b[0]);
	});

const maxCount = Math.max(...Array.from(tagCounts.values()), 1);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags — ${SITE_TITLE}`} description="Browse all tags" />
		<style>
			body {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			#main-content {
				flex: 1;
			}

			.page-container {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}



			.page-header {
				text-align: center;
				margin-bottom: 2.5em;
				animation: fadeInUp 0.4s ease forwards;
			}

			.page-header h1 {
				font-size: 2.4em;
				margin: 0 0 0.3em;
				background: linear-gradient(135deg, var(--mauve), var(--blue), var(--lavender));
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 6s ease infinite;
			}

			.page-header .page-label {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.78em;
				color: var(--subtext0);
				background: var(--card-bg);
				padding: 0.35em 0.9em;
				border-radius: 6px;
				border: 1px solid var(--card-border);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				margin-bottom: 1em;
			}

			.page-label-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--blue);
			}

			.page-subtitle {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.85em;
				color: var(--subtext0);
				margin: 0;
			}

			.tags-grid {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.75rem;
				padding: 2rem;
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 16px;
			}

			.tag-item {
				animation: fadeInUp 0.3s ease forwards;
				opacity: 0;
			}

			.tag-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: "JetBrains Mono", monospace;
				text-decoration: none;
				padding: 0.5em 0.9em;
				background: var(--surface0);
				border: 1px solid var(--surface1);
				border-radius: 8px;
				transition: all 0.2s ease;
			}

			.tag-link:hover {
				background: var(--surface1);
				border-color: var(--accent);
				transform: translateY(-2px);
				text-decoration: none;
			}

			.tag-name {
				color: var(--text);
				font-weight: 500;
			}

			.tag-hash {
				color: var(--accent);
			}

			.tag-count {
				font-size: 0.8em;
				color: var(--base);
				background: var(--accent);
				padding: 0.1em 0.45em;
				border-radius: 4px;
				font-weight: 600;
			}

			/* Size variants based on frequency */
			.tag-size-1 .tag-link { font-size: 0.8em; }
			.tag-size-2 .tag-link { font-size: 0.88em; }
			.tag-size-3 .tag-link { font-size: 0.95em; }
			.tag-size-4 .tag-link { font-size: 1.02em; }
			.tag-size-5 .tag-link { font-size: 1.1em; }

			.empty-state {
				text-align: center;
				padding: 3rem;
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 16px;
			}

			.empty-state p {
				color: var(--subtext0);
				font-family: "JetBrains Mono", monospace;
				margin: 0;
			}

			@media (max-width: 600px) {
				.tags-grid {
					padding: 1.25rem;
					gap: 0.5rem;
				}

				.tag-link {
					padding: 0.4em 0.7em;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.page-header,
				.tag-item {
					animation: none;
					opacity: 1;
				}

				.page-title {
					animation: none;
					background-size: 100% 100%;
				}

				.tag-link:hover {
					transform: none;
				}
			}
		</style>
	</head>
	<body>
		<ParticleBackground />
		<LorenzBackground />
		<TorusKnotBackground />
		<Header />
		<main id="main-content">
			<div class="page-container">


				<header class="page-header">
					<span class="page-label">
						<span class="page-label-dot"></span>
						~/blogs/tags
					</span>
					<h1>All Tags</h1>
					<p class="page-subtitle">{sortedTags.length} {sortedTags.length === 1 ? 'tag' : 'tags'} across {posts.length} posts</p>
					<hr style="margin-top: 1.5em;" />
				</header>

				{sortedTags.length === 0 ? (
					<div class="empty-state">
						<p>No tags found yet.</p>
					</div>
				) : (
					<div class="tags-grid">
						{sortedTags.map(([tag, count], index) => {
							const sizeClass = Math.min(5, Math.max(1, Math.ceil((count / maxCount) * 5)));
							return (
								<div class={`tag-item tag-size-${sizeClass}`} style={`animation-delay: ${index * 0.02}s`}>
									<a href={`${base}tags/${tag}/`} class="tag-link">
										<span class="tag-name"><span class="tag-hash">#</span>{tag}</span>
										<span class="tag-count">{count}</span>
									</a>
								</div>
							);
						})}
					</div>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>