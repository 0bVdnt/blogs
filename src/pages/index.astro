---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid rgba(0, 255, 204, 0.2);
			}
			.intro h1 {
				font-size: 2rem;
			}
			.intro p {
				opacity: 0.85;
			}
			section ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			section ul li {
				width: calc(50% - 1rem);
			}
			section ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			section ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			section ul li:first-child img {
				width: 100%;
			}
			section ul li:first-child .title {
				font-size: 2.369rem;
			}
			section ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			section ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: var(--accent);
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			section ul li a:hover h4,
			section ul li a:hover .date {
				color: var(--accent-dark);
			}
			section ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				section ul {
					gap: 0.5em;
				}
				section ul li {
					width: 100%;
					text-align: center;
				}
				section ul li:first-child {
					margin-bottom: 0;
				}
				section ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<h1><span style="color: var(--accent);">></span> 0bVdnt_Blog</h1>
				<p>
					Welcome to my integrated systems blog — an extension of my
					<a href="https://0bVdnt.github.io/">interactive OS portfolio</a>.
					Thoughts on systems, coding, and the web.
				</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${base}${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
