---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import LorenzBackground from '../components/LorenzBackground.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import TorusKnotBackground from '../components/TorusKnotBackground.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function estimateReadingTime(body: string | undefined): string {
	if (!body) return '1 min';
	// Strip markdown syntax before counting
	const plain = body
		.replace(/```[\s\S]*?```/g, '')   // code blocks
		.replace(/`[^`]*`/g, '')           // inline code
		.replace(/[#*_~>\[\]()!|-]/g, '')  // md symbols
		.replace(/https?:\/\/\S+/g, '');   // urls
	const words = plain.split(/\s+/).filter(w => w.length > 0).length;
	const minutes = Math.max(1, Math.ceil(words / 200));
	return `${minutes} min`;
}

// Calculate total stats
const totalWords = posts.reduce((sum, post) => {
	if (!post.body) return sum;
	const plain = post.body
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]*`/g, '')
		.replace(/[#*_~>\[\]()!|-]/g, '')
		.replace(/https?:\/\/\S+/g, '');
	const words = plain.split(/\s+/).filter(w => w.length > 0).length;
	return sum + words;
}, 0);

const totalReadingTime = Math.ceil(totalWords / 200);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ===== Hero ===== */
			.hero {
				text-align: center;
				padding: 1.5rem 0 3rem;
				margin-bottom: 2rem;
				position: relative;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				width: 600px;
				height: 300px;
				background: radial-gradient(ellipse at center, var(--glow-color) 0%, transparent 60%);
				z-index: -1;
				pointer-events: none;
				filter: blur(40px);
			}

			.hero-terminal {
				display: inline-block;
				text-align: left;
				max-width: 720px;
				width: 100%;
				box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
				border-radius: 12px;
				border: 1px solid var(--surface2);
				background: var(--crust);
				position: relative;
				z-index: 10;
			}

			.terminal-bar {
				display: flex;
				align-items: center;
				gap: 8px;
				padding: 12px 16px;
				background: var(--mantle);
				border-radius: 11px 11px 0 0;
				border-bottom: 1px solid var(--surface1);
			}

			.terminal-dot {
				width: 12px;
				height: 12px;
				border-radius: 50%;
				box-shadow: inset 0 1px 2px rgba(0,0,0,0.4);
			}

			.terminal-dot.red { background: var(--red); }
			.terminal-dot.yellow { background: var(--yellow); }
			.terminal-dot.green { background: var(--green); }

			.terminal-title {
				flex: 1;
				text-align: center;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--overlay1);
				margin-right: 56px;
				font-weight: 600;
			}

			.terminal-body {
				padding: 2.5rem 3rem 3rem;
				position: relative;
				overflow: hidden;
				border-radius: 0 0 11px 11px;
			}

			.tech-corner {
				position: absolute;
				width: 12px;
				height: 12px;
				border: 2px solid var(--surface2);
				opacity: 0.5;
			}
			.tc-tl { top: 16px; left: 16px; border-right: none; border-bottom: none; }
			.tc-tr { top: 16px; right: 16px; border-left: none; border-bottom: none; }
			.tc-bl { bottom: 16px; left: 16px; border-right: none; border-top: none; }
			.tc-br { bottom: 16px; right: 16px; border-left: none; border-top: none; }

			.hero-title {
				font-family: "JetBrains Mono", monospace;
				font-size: 2.6em;
				font-weight: 800;
				margin: 0 0 0.5em;
				background: linear-gradient(135deg, var(--mauve), var(--blue), var(--lavender));
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 6s ease infinite;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}

			.hero-prompt {
				-webkit-text-fill-color: var(--green);
			}

			.cursor {
				display: inline-block;
				width: 3px;
				height: 1em;
				background: var(--green);
				margin-left: 2px;
				animation: blink 1s step-end infinite;
				vertical-align: middle;
				box-shadow: 0 0 8px var(--green);
				border-radius: 1px;
			}

			@keyframes blink {
				0%, 100% { opacity: 1; }
				50% { opacity: 0; }
			}

			.hero-subtitle {
				color: var(--subtext0);
				font-size: 1.05em;
				line-height: 1.7;
				margin: 0;
			}

			.hero-subtitle a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px dashed var(--accent);
			}

			.hero-subtitle a:hover {
				border-bottom-style: solid;
			}

			/* ===== Section Header ===== */
			.section-header {
				display: flex;
				align-items: center;
				gap: 1em;
				margin-bottom: 2rem;
				max-width: 720px;
				margin-left: auto;
				margin-right: auto;
			}

			.section-header h2 {
				font-family: "JetBrains Mono", monospace;
				font-size: 1em;
				font-weight: 600;
				color: var(--subtext0);
				margin: 0;
				white-space: nowrap;
			}

			.section-header .section-line {
				flex: 1;
				height: 1px;
				background: linear-gradient(to right, var(--surface1), transparent);
			}

			.section-header .post-count {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--overlay0);
				background: var(--card-bg);
				padding: 0.2em 0.6em;
				border-radius: 6px;
				border: 1px solid var(--card-border);
			}

			/* ===== Posts Grid ===== */
			.posts-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
				max-width: 720px;
				margin: 0 auto;
			}

			/* ===== Interactive Cards ===== */
			.post-card {
				perspective: 1000px;
				animation: fadeInUp 0.5s ease forwards;
				opacity: 0;
				display: flex;
				width: 100%;
			}

			.post-card:nth-child(1) { animation-delay: 0.05s; }
			.post-card:nth-child(2) { animation-delay: 0.15s; }
			.post-card:nth-child(3) { animation-delay: 0.25s; }
			.post-card:nth-child(4) { animation-delay: 0.35s; }
			.post-card:nth-child(5) { animation-delay: 0.45s; }
			.post-card:nth-child(6) { animation-delay: 0.55s; }

			.card-link {
				display: flex;
				width: 100%;
				text-decoration: none;
				color: inherit;
				outline: none;
			}

			.card-link:hover {
				text-decoration: none;
			}

			.card-inner {
				display: flex;
				flex-direction: row;
				align-items: stretch;
				width: 100%;
				background: rgba(30, 30, 46, 0.4);
				border: 1px solid var(--surface0);
				border-left: 4px solid transparent;
				border-radius: 16px;
				overflow: hidden;
				transition: transform 0.25s ease, box-shadow 0.3s ease, border-color 0.3s ease, background 0.3s ease;
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				position: relative;
				padding: 0.5rem;
			}

			:global([data-theme="latte"]) .card-inner {
				background: rgba(255, 255, 255, 0.6);
			}

			.card-inner::before {
				content: "";
				position: absolute;
				top: 0; left: 0; right: 0; bottom: 0;
				background: radial-gradient(
					600px circle at var(--mouse-x, -500px) var(--mouse-y, -500px),
					var(--glow-color),
					transparent 40%
				);
				z-index: 1;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			.card-inner::after {
				content: "";
				position: absolute;
				inset: 0px;
				border-radius: inherit;
				padding: 1px;
				background: radial-gradient(
					400px circle at var(--mouse-x, -500px) var(--mouse-y, -500px),
					rgba(255, 255, 255, 0.4),
					transparent 40%
				);
				-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				-webkit-mask-composite: xor;
				mask-composite: exclude;
				z-index: 2;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			:global([data-theme="mocha"]) .card-inner::after {
				background: radial-gradient(
					400px circle at var(--mouse-x, -500px) var(--mouse-y, -500px),
					var(--mauve),
					transparent 40%
				);
			}

			.card-inner:hover::before,
			.card-inner:hover::after {
				opacity: 1;
			}

			.card-inner:hover {
				box-shadow: 0 12px 30px rgba(0,0,0,0.15);
				background: rgba(30, 30, 46, 0.7);
				border-color: var(--surface1);
				border-left-color: var(--mauve);
			}

			:global([data-theme="latte"]) .card-inner:hover {
				background: rgba(255, 255, 255, 0.9);
			}

			.card-image, .card-body {
				position: relative;
				z-index: 3;
			}

			.card-image {
				width: 240px;
				height: 100%;
				min-height: 160px;
				flex-shrink: 0;
				overflow: hidden;
				border-radius: 12px;
				margin: 0.5rem;
			}

			.card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: inherit;
				transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
			}

			.card-inner:hover .card-image img {
				transform: scale(1.05);
			}

			.card-body {
				flex: 1;
				padding: 1.5rem 2rem;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.card-meta {
				display: flex;
				align-items: center;
				gap: 0.6em;
				margin-bottom: 0.75em;
				flex-wrap: wrap;
			}

			.card-date {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--mauve);
				background: rgba(203, 166, 247, 0.1);
				padding: 0.2em 0.65em;
				border-radius: 6px;
				border: 1px solid rgba(203, 166, 247, 0.15);
			}

			:global([data-theme="latte"]) .card-date {
				color: var(--mauve);
				background: rgba(136, 57, 239, 0.08);
				border-color: rgba(136, 57, 239, 0.15);
			}

			.card-reading-time {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.7em;
				color: var(--overlay1);
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
			}

			.card-reading-time svg {
				width: 14px;
				height: 14px;
				flex-shrink: 0;
			}

			.card-filename {
				font-family: "JetBrains Mono", monospace;
				font-size: 0.7em;
				color: var(--overlay0);
				margin-left: auto;
			}

			.card-title {
				font-family: "JetBrains Mono", monospace;
				font-size: 1.25em;
				font-weight: 700;
				color: var(--text);
				margin: 0;
				line-height: 1.35;
				transition: color 0.2s ease;
			}

			.card-inner:hover .card-title {
				color: var(--accent);
			}

			.card-excerpt {
				color: var(--subtext0);
				font-size: 0.9em;
				margin: 0.5em 0 0;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* Arrow indicator */
			.card-arrow {
				position: relative;
				z-index: 3;
				display: flex;
				align-items: center;
				padding-right: 1rem;
				color: var(--overlay0);
				transition: color 0.2s ease, transform 0.2s ease;
			}

			.card-inner:hover .card-arrow {
				color: var(--accent);
				transform: translateX(4px);
			}

			/* ===== Empty State ===== */
			.empty-state {
				text-align: center;
				padding: 4rem 1rem;
				font-family: "JetBrains Mono", monospace;
				max-width: 720px;
				margin: 0 auto;
			}

			.empty-terminal {
				display: inline-block;
				text-align: left;
				max-width: 400px;
				width: 100%;
				border-radius: 12px;
				border: 1px solid var(--surface2);
				background: var(--crust);
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
				animation: fadeInUp 0.5s ease forwards;
			}

			.empty-terminal .terminal-bar {
				display: flex;
				align-items: center;
				gap: 8px;
				padding: 10px 14px;
				background: var(--mantle);
				border-radius: 11px 11px 0 0;
				border-bottom: 1px solid var(--surface1);
			}

			.empty-terminal .terminal-body {
				padding: 1.5rem 2rem;
			}

			.empty-prompt {
				font-size: 0.9em;
				color: var(--green);
				margin: 0 0 0.5em;
			}

			.empty-output {
				color: var(--overlay1);
				font-size: 0.85em;
				margin: 0;
			}

			/* ===== Responsive ===== */
			@media (max-width: 720px) {
				.hero-title { font-size: 1.9em; }
				.terminal-body { padding: 1.5rem 1.5rem; }
				.card-inner { flex-direction: column; padding: 0; }
				.card-image { width: 100%; margin: 0; border-radius: 16px 16px 0 0; min-height: unset; aspect-ratio: 16/9; }
				.card-body { padding: 1.25rem 1.5rem; }
				.card-filename { display: none; }
				.card-arrow { display: none; }
				.section-header { padding: 0 0.25rem; }
			}

			/* ===== Reduced Motion ===== */
			@media (prefers-reduced-motion: reduce) {
				.post-card {
					opacity: 1 !important;
					animation: none !important;
				}

				.hero-title {
					animation: none !important;
					background-size: 100% 100% !important;
				}

				.cursor {
					animation: none !important;
					opacity: 1 !important;
				}

				.card-inner {
					transition: none !important;
				}

				.card-inner:hover {
					transform: none !important;
				}

				.card-image img {
					transition: none !important;
				}

				.empty-terminal {
					animation: none !important;
					opacity: 1 !important;
				}
			}
		</style>
	</head>
	<body>
		<ParticleBackground />
		<LorenzBackground />
		<TorusKnotBackground />
		<Header />
		<main id="main-content">
			<div class="hero">
				<div class="hero-terminal">
					<div class="terminal-bar">
						<span class="terminal-dot red"></span>
						<span class="terminal-dot yellow"></span>
						<span class="terminal-dot green"></span>
						<span class="terminal-title">~/0bVdnt/blogs</span>
					</div>
					<div class="terminal-body">
						<div class="tech-corner tc-tl"></div>
						<div class="tech-corner tc-tr"></div>
						<div class="tech-corner tc-bl"></div>
						<div class="tech-corner tc-br"></div>
						<h1 class="hero-title">
							<span class="hero-prompt">&gt;</span> <span id="scramble-target" data-value="0bVdnt_Blog">_</span><span class="cursor"></span>
						</h1>
						<p class="hero-subtitle">
							An extension of my
							<a href="https://0bVdnt.github.io/">interactive OS portfolio</a> —
							deep-dives into systems, algorithms, and the craft of code.
						</p>
					</div>
				</div>
			</div>

			{posts.length === 0 ? (
				<div class="empty-state">
					<div class="empty-terminal">
						<div class="terminal-bar">
							<span class="terminal-dot red"></span>
							<span class="terminal-dot yellow"></span>
							<span class="terminal-dot green"></span>
						</div>
						<div class="terminal-body">
							<p class="empty-prompt">$ ls ./posts</p>
							<p class="empty-output">No entries found.</p>
							<p class="empty-output">Check back soon.</p>
						</div>
					</div>
				</div>
			) : (
				<section>
					<div class="section-header">
						<h2>~/blogs/posts</h2>
						<div class="section-line"></div>
						<span class="post-count">{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</span>
					</div>
					<ul class="posts-grid" id="cards-container">
						{posts.map((post) => (
							<li class="post-card">
								<a href={`${base}${post.id}/`} class="card-link">
									<div class="card-inner">
										{post.data.heroImage && (
											<div class="card-image">
												<Image
													width={800}
													height={450}
													src={post.data.heroImage}
													alt={post.data.title}
												/>
											</div>
										)}
										<div class="card-body">
											<div class="card-meta">
												<span class="card-date">
													<FormattedDate date={post.data.pubDate} />
												</span>
												<span class="card-reading-time">
													<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
													{estimateReadingTime(post.body)}
												</span>
												<span class="card-filename">~/blogs/{post.id}.md</span>
											</div>
											<h4 class="card-title">{post.data.title}</h4>
											{post.data.description && (
												<p class="card-excerpt">{post.data.description}</p>
											)}
										</div>
										<div class="card-arrow">
											<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
										</div>
									</div>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />

		<!-- Interactive JS Effects -->
		<script is:inline>
			(function() {
				// --- Text Scramble Effect ---
				const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+";
				let scrambleInterval = null;
				const el = document.getElementById("scramble-target");

				if (el) {
					const targetText = el.getAttribute("data-value");
					let iteration = 0;

					scrambleInterval = setInterval(() => {
						el.innerText = targetText
							.split("")
							.map((letter, index) => {
								if(index < iteration) return targetText[index];
								return letters[Math.floor(Math.random() * 48)];
							})
							.join("");

						if(iteration >= targetText.length){
							clearInterval(scrambleInterval);
							scrambleInterval = null;
						}

						iteration += 1 / 3;
					}, 30);
				}

				document.addEventListener('astro:before-swap', () => {
					if (scrambleInterval) {
						clearInterval(scrambleInterval);
						scrambleInterval = null;
					}
				});

				// --- Mouse Spotlight & 3D Tilt ---
				const isTouchDevice = window.matchMedia('(hover: none)').matches;
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				if (!prefersReducedMotion) {
					const cards = document.querySelectorAll(".card-inner");

					for (const card of cards) {
						card.addEventListener("mousemove", e => {
							const rect = card.getBoundingClientRect();
							const x = e.clientX - rect.left;
							const y = e.clientY - rect.top;

							card.style.setProperty("--mouse-x", `${x}px`);
							card.style.setProperty("--mouse-y", `${y}px`);

							if (!isTouchDevice) {
								const centerX = rect.width / 2;
								const centerY = rect.height / 2;
								const rotateX = ((y - centerY) / centerY) * -4;
								const rotateY = ((x - centerX) / centerX) * 4;

								card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
							}
						});

						card.addEventListener("mouseleave", () => {
							card.style.transform = '';
							card.style.removeProperty("--mouse-x");
							card.style.removeProperty("--mouse-y");
						});

						card.addEventListener("touchend", () => {
							card.style.transform = '';
						});
					}
				}
			})();
		</script>
	</body>
</html>