---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import CopyCodeButton from '../components/CopyCodeButton.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostMeta from '../components/PostMeta.astro';
import PostNavigation from '../components/PostNavigation.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface NavPost {
	id: string;
	title: string;
}

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	lastModified?: Date;
	heroImage?: ImageMetadata;
	body?: string;
	headings?: Heading[];
	prevPost?: NavPost;
	nextPost?: NavPost;
	basePath?: string;
	postId?: string;
	tags?: string[];
}

const { 
	title, 
	description, 
	pubDate, 
	updatedDate, 
	lastModified, 
	heroImage, 
	body, 
	headings = [],
	prevPost,
	nextPost,
	basePath = '/blogs/',
	postId = '',
	tags = []
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

function getPostStats(content: string | undefined): { readingTime: string; wordCount: number } {
	if (!content) return { readingTime: '1 min read', wordCount: 0 };
	const plain = content
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]*`/g, '')
		.replace(/[#*_~>\[\]()!|-]/g, '')
		.replace(/https?:\/\/\S+/g, '');
	const words = plain.split(/\s+/).filter(w => w.length > 0);
	const wordCount = words.length;
	const minutes = Math.max(1, Math.ceil(wordCount / 200));
	return { readingTime: `${minutes} min read`, wordCount };
}

const { readingTime, wordCount } = getPostStats(body);
const showToc = headings.filter(h => h.depth === 2 || h.depth === 3).length >= 3;

const displayUpdatedDate = updatedDate || lastModified;
const showUpdated = displayUpdatedDate && displayUpdatedDate.getTime() > pubDate.getTime() + 86400000;
const isFileModified = !updatedDate && lastModified;

const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={title} 
			description={description} 
			type="article"
			articleDate={pubDate}
			updatedDate={displayUpdatedDate}
			tags={tags}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: auto;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.82em;
				color: var(--subtext0);
				text-decoration: none;
				padding: 0.5em 0.9em;
				border-radius: 8px;
				border: 1px solid var(--surface0);
				border-bottom: 2px dashed var(--surface1);
				background: var(--card-bg);
				transition: all 0.2s ease;
				margin-bottom: 2em;
			}

			.back-link:hover {
				color: var(--accent);
				border-color: var(--accent);
				border-bottom: 2px solid var(--accent);
				background: var(--surface0);
				text-decoration: none;
			}

			.back-link svg {
				width: 16px;
				height: 16px;
				transition: transform 0.2s ease;
			}

			.back-link:hover svg {
				transform: translateX(-3px);
			}

			.hero-image {
				width: 100%;
				max-width: 900px;
				margin: 0 auto 2em;
				animation: fadeInUp 0.5s ease forwards;
			}

			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 14px;
				box-shadow: 0 6px 24px var(--shadow-color);
			}

			.prose {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text);
			}

			.article-header {
				margin-bottom: 2em;
				text-align: center;
				animation: fadeInUp 0.4s ease forwards;
			}

			.post-meta-row {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5em;
				margin-bottom: 1.25em;
				flex-wrap: wrap;
			}

			.meta-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.35em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.73em;
				color: var(--subtext0);
				background: var(--card-bg);
				padding: 0.35em 0.75em;
				border-radius: 6px;
				border: 1px solid var(--card-border);
				white-space: nowrap;
			}

			.meta-badge svg {
				flex-shrink: 0;
				width: 12px;
				height: 12px;
			}

			.meta-badge.date-badge {
				color: var(--mauve);
				border-color: rgba(203, 166, 247, 0.15);
				background: rgba(203, 166, 247, 0.1);
			}

			:global([data-theme="latte"]) .meta-badge.date-badge {
				color: var(--mauve);
				background: rgba(136, 57, 239, 0.08);
				border-color: rgba(136, 57, 239, 0.15);
			}

			.meta-badge.updated-badge {
				color: var(--peach);
				border-color: rgba(250, 179, 135, 0.15);
				background: rgba(250, 179, 135, 0.1);
			}

			:global([data-theme="latte"]) .meta-badge.updated-badge {
				color: var(--peach);
				background: rgba(254, 100, 11, 0.08);
				border-color: rgba(254, 100, 11, 0.15);
			}

			.article-header h1 {
				font-size: 2.2em;
				margin: 0 0 0.3em;
				background: linear-gradient(135deg, var(--mauve), var(--blue), var(--lavender));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.article-description {
				font-size: 1.1em;
				color: var(--subtext0);
				margin: 0.5em auto 0;
				max-width: 85%;
				line-height: 1.6;
			}

			.article-tags {
				display: flex;
				justify-content: center;
				margin-top: 1.25em;
			}

			.prose :global(h2) {
				margin-top: 2.5em;
				padding-bottom: 0.3em;
				border-bottom: 1px solid var(--card-border);
			}

			.prose :global(h3) { margin-top: 2em; }

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.75em;
			}

			.prose :global(li) {
				margin-bottom: 0.5em;
				line-height: 1.7;
			}

			.prose :global(li code) {
				font-size: 0.85em;
			}

			.prose :global(a) {
				color: var(--link);
				text-decoration: none;
				border-bottom: 1px dashed var(--link);
				transition: all 0.2s ease;
			}

			.prose :global(a:hover) {
				color: var(--link-hover);
				border-bottom-style: solid;
			}

			.prose :global(img) {
				border-radius: 12px;
				margin: 1.5em 0;
				box-shadow: 0 4px 16px var(--shadow-color);
			}

			.prose :global(pre) {
				margin: 1.5em 0;
				position: relative;
			}

			.prose :global(p code) {
				word-break: break-word;
			}

			@media (max-width: 720px) {
				.prose { padding: 0.5em; }
				.article-header h1 { font-size: 1.7em; }
				.article-description { 
					font-size: 1em; 
					max-width: 100%; 
				}
				.hero-image { margin-bottom: 1em; }
				.hero-image img { border-radius: 10px; }
				
				.date-info {
					font-size: 0.7em;
					padding: 0.35em 0.8em;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.article-header {
					animation: none;
					opacity: 1;
				}
				.article-header h1 {
					animation: none;
					background-size: 100% 100%;
				}
				.hero-image {
					animation: none;
					opacity: 1;
				}
				.date-dot {
					animation: none;
					opacity: 0.6;
				}
				.back-link svg {
					transition: none;
				}
			}
		</style>
	</head>

	<body>
		<ReadingProgress />
		<Header />
		<main id="main-content">
			<article>
				<div class="prose">
					<a href={base} class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
						cd ~/blogs
					</a>
					
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt={title} />
						</div>
					)}
					
					<header class="article-header">
						<div class="post-meta-row">
							<span class="meta-badge date-badge">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
								<FormattedDate date={pubDate} />
							</span>
							<span class="meta-badge">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
								{readingTime}
							</span>
							<span class="meta-badge">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
								{wordCount.toLocaleString()} words
							</span>
							{showUpdated && (
								<span class="meta-badge updated-badge">
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
									{isFileModified ? 'Modified' : 'Updated'} <FormattedDate date={displayUpdatedDate!} />
								</span>
							)}
						</div>
						<h1>{title}</h1>
						{description && <p class="article-description">{description}</p>}
						{tags.length > 0 && (
							<div class="article-tags">
								<TagList tags={tags} basePath={base} size="md" />
							</div>
						)}
					</header>
					
					<hr />
					
					{showToc && <TableOfContents headings={headings} />}
					
					<slot />
					
					<ShareButtons title={title} url={fullUrl} />
					
					{tags.length > 0 && (
						<RelatedPosts currentPostId={postId} currentTags={tags} basePath={base} />
					)}
					
					<PostNavigation prevPost={prevPost} nextPost={nextPost} basePath={basePath} />
					
					{postId && <PostMeta postId={postId} />}
				</div>
			</article>
		</main>
		<Footer />
		<CopyCodeButton />
		<ScrollToTop />
	</body>
</html>