---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import CopyCodeButton from '../components/CopyCodeButton.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import LorenzBackground from '../components/LorenzBackground.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import PostMeta from '../components/PostMeta.astro';
import PostNavigation from '../components/PostNavigation.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';
import TorusKnotBackground from '../components/TorusKnotBackground.astro';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface NavPost {
	id: string;
	title: string;
}

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	lastModified?: Date;
	heroImage?: ImageMetadata;
	body?: string;
	headings?: Heading[];
	prevPost?: NavPost;
	nextPost?: NavPost;
	basePath?: string;
	postId?: string;
	tags?: string[];
}

const { 
	title, 
	description, 
	pubDate, 
	updatedDate, 
	lastModified, 
	heroImage, 
	body, 
	headings = [],
	prevPost,
	nextPost,
	basePath = '/blogs/',
	postId = '',
	tags = []
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

function getPostStats(content: string | undefined): { readingTime: string; wordCount: number } {
	if (!content) return { readingTime: '1 min read', wordCount: 0 };
	const plain = content
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]*`/g, '')
		.replace(/[#*_~>\[\]()!|-]/g, '')
		.replace(/https?:\/\/\S+/g, '');
	const words = plain.split(/\s+/).filter(w => w.length > 0);
	const wordCount = words.length;
	const minutes = Math.max(1, Math.ceil(wordCount / 200));
	return { readingTime: `${minutes} min read`, wordCount };
}

const { readingTime, wordCount } = getPostStats(body);
const showToc = headings.filter(h => h.depth === 2 || h.depth === 3).length >= 3;

const displayUpdatedDate = updatedDate || lastModified;
const showUpdated = displayUpdatedDate && displayUpdatedDate.getTime() > pubDate.getTime() + 86400000;
const isFileModified = !updatedDate && lastModified;

const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.82em;
				color: var(--subtext0);
				text-decoration: none;
				padding: 0.4em 0.8em;
				border-radius: 8px;
				transition: all 0.2s ease;
				margin-bottom: 2em;
			}

			.back-link:hover {
				color: var(--accent);
				background: var(--card-bg);
				text-decoration: none;
			}

			.back-link svg {
				width: 16px;
				height: 16px;
				transition: transform 0.2s ease;
			}

			.back-link:hover svg {
				transform: translateX(-3px);
			}

			.hero-image {
				width: 100%;
				max-width: 900px;
				margin: 0 auto 2em;
				animation: fadeInUp 0.5s ease forwards;
			}

			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 14px;
				box-shadow: 0 6px 24px var(--shadow-color);
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text);
			}

			.article-header {
				margin-bottom: 2em;
				text-align: center;
				animation: fadeInUp 0.4s ease forwards;
			}

			.date-info {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: "JetBrains Mono", monospace;
				font-size: 0.75em;
				color: var(--subtext0);
				background: var(--card-bg);
				padding: 0.4em 1em;
				border-radius: 20px;
				border: 1px solid var(--card-border);
				margin-bottom: 1.25em;
				flex-wrap: wrap;
				justify-content: center;
			}

			.date-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--green);
				animation: glow-pulse 2s ease-in-out infinite;
			}

			.date-separator {
				color: var(--overlay0);
			}

			.reading-time {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
			}

			.reading-time svg {
				flex-shrink: 0;
			}

			.word-count {
				color: var(--overlay1);
			}

			.last-updated-on {
				color: var(--overlay1);
			}

			.article-header h1 {
				font-size: 2.2em;
				margin: 0 0 0.3em;
				background: linear-gradient(135deg, var(--mauve), var(--blue), var(--lavender));
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 6s ease infinite;
			}

			.article-tags {
				display: flex;
				justify-content: center;
				margin-top: 1.25em;
			}

			.prose :global(h2) {
				margin-top: 2.5em;
				padding-bottom: 0.3em;
				border-bottom: 1px solid var(--card-border);
			}

			.prose :global(h3) { margin-top: 2em; }

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.75em;
			}

			.prose :global(li) {
				margin-bottom: 0.5em;
				line-height: 1.7;
			}

			.prose :global(li code) {
				font-size: 0.85em;
			}

			.prose :global(a) {
				color: var(--link);
				text-decoration: none;
				border-bottom: 1px dashed var(--link);
				transition: all 0.2s ease;
			}

			.prose :global(a:hover) {
				color: var(--link-hover);
				border-bottom-style: solid;
			}

			.prose :global(img) {
				border-radius: 12px;
				margin: 1.5em 0;
				box-shadow: 0 4px 16px var(--shadow-color);
			}

			.prose :global(pre) {
				margin: 1.5em 0;
				position: relative;
			}

			.prose :global(p code) {
				word-break: break-word;
			}

			@media (max-width: 720px) {
				.article-header h1 { font-size: 1.7em; }
				.hero-image { margin-bottom: 1em; }
				.hero-image img { border-radius: 10px; }
				
				.date-info {
					font-size: 0.7em;
					padding: 0.35em 0.8em;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.article-header {
					animation: none;
					opacity: 1;
				}
				.article-header h1 {
					animation: none;
					background-size: 100% 100%;
				}
				.hero-image {
					animation: none;
					opacity: 1;
				}
				.date-dot {
					animation: none;
					opacity: 0.6;
				}
				.back-link svg {
					transition: none;
				}
			}
		</style>
	</head>

	<body>
		<ReadingProgress />
		<ParticleBackground />
		<LorenzBackground />
		<TorusKnotBackground />
		<Header />
		<main id="main-content">
			<article>
				<div class="prose">
					<a href={base} class="back-link">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
						cd ~/blogs
					</a>
					
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt={title} />
						</div>
					)}
					
					<header class="article-header">
						<div class="date-info">
							<span class="date-dot"></span>
							<FormattedDate date={pubDate} />
							<span class="date-separator">·</span>
							<span class="reading-time">
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="12" height="12"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
								{readingTime}
							</span>
							<span class="date-separator">·</span>
							<span class="word-count">{wordCount.toLocaleString()} words</span>
							{showUpdated && (
								<>
									<span class="date-separator">·</span>
									<span class="last-updated-on">
										{isFileModified ? 'Modified' : 'Updated'} <FormattedDate date={displayUpdatedDate!} />
									</span>
								</>
							)}
						</div>
						<h1>{title}</h1>
						{tags.length > 0 && (
							<div class="article-tags">
								<TagList tags={tags} basePath={base} size="md" />
							</div>
						)}
					</header>
					
					<hr />
					
					{showToc && <TableOfContents headings={headings} />}
					
					<slot />
					
					<ShareButtons title={title} url={fullUrl} />
					
					{tags.length > 0 && (
						<RelatedPosts currentPostId={postId} currentTags={tags} basePath={base} />
					)}
					
					{postId && <PostMeta postId={postId} />}
					
					<PostNavigation prevPost={prevPost} nextPost={nextPost} basePath={basePath} />
				</div>
			</article>
		</main>
		<Footer />
		<CopyCodeButton />
		<ScrollToTop />
	</body>
</html>