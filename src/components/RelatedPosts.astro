---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentPostId: string;
	currentTags: string[];
	basePath: string;
	limit?: number;
}

const { currentPostId, currentTags, basePath, limit = 3 } = Astro.props;

const allPosts = await getCollection('blog');

const scoredPosts = allPosts
	.filter(post => post.id !== currentPostId)
	.map(post => {
		const postTags = post.data.tags || [];
		const overlap = postTags.filter(tag => currentTags.includes(tag)).length;
		return { post, score: overlap };
	})
	.filter(item => item.score > 0)
	.sort((a, b) => {
		if (b.score !== a.score) return b.score - a.score;
		return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
	})
	.slice(0, limit);
---

{scoredPosts.length > 0 && (
	<aside class="related-posts">
		<header class="related-header">
			<span class="related-icon">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="18" cy="5" r="3"/>
					<circle cx="6" cy="12" r="3"/>
					<circle cx="18" cy="19" r="3"/>
					<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
					<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
				</svg>
			</span>
			<h3 class="related-title">Related Posts</h3>
		</header>
		<ul class="related-list">
			{scoredPosts.map(({ post, score }) => (
				<li>
					<a href={`${basePath}${post.id}/`} class="related-link">
						<div class="related-content">
							<span class="related-date">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<h4 class="related-post-title">{post.data.title}</h4>
						</div>
						<span class="related-arrow">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
						</span>
					</a>
				</li>
			))}
		</ul>
	</aside>
)}

<style>
	.related-posts {
		margin-top: 3rem;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 12px;
		overflow: hidden;
	}

	.related-header {
		display: flex;
		align-items: center;
		gap: 0.6em;
		padding: 1rem 1.25rem;
		background: var(--surface0);
		border-bottom: 1px solid var(--card-border);
	}

	.related-icon {
		display: flex;
		color: var(--accent);
	}

	.related-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.82em;
		font-weight: 600;
		color: var(--text);
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.related-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.related-list li {
		border-bottom: 1px solid var(--surface0);
	}

	.related-list li:last-child {
		border-bottom: none;
	}

	.related-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		text-decoration: none;
		transition: background 0.15s ease;
	}

	.related-link:hover {
		background: var(--surface0);
		text-decoration: none;
	}

	.related-content {
		flex: 1;
		min-width: 0;
	}

	.related-date {
		display: block;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7em;
		color: var(--overlay1);
		margin-bottom: 0.3em;
	}

	.related-post-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.9em;
		font-weight: 500;
		color: var(--text);
		margin: 0;
		line-height: 1.4;
		transition: color 0.15s ease;
	}

	.related-link:hover .related-post-title {
		color: var(--accent);
	}

	.related-arrow {
		flex-shrink: 0;
		color: var(--overlay0);
		transition: all 0.15s ease;
	}

	.related-link:hover .related-arrow {
		color: var(--accent);
		transform: translateX(2px);
	}

	@media (prefers-reduced-motion: reduce) {
		.related-link,
		.related-arrow {
			transition: none;
		}

		.related-link:hover .related-arrow {
			transform: none;
		}
	}
</style>