---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentPostId: string;
	currentTags: string[];
	basePath: string;
	limit?: number;
}

const { currentPostId, currentTags, basePath, limit = 3 } = Astro.props;

const allPosts = await getCollection('blog');

const scoredPosts = allPosts
	.filter(post => post.id !== currentPostId)
	.map(post => {
		const postTags = post.data.tags || [];
		const overlap = postTags.filter(tag => currentTags.includes(tag)).length;
		return { post, score: overlap };
	})
	.filter(item => item.score > 0)
	.sort((a, b) => {
		if (b.score !== a.score) return b.score - a.score;
		return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
	})
	.slice(0, limit);
---

{scoredPosts.length > 0 && (
	<aside class="related-posts">
		<div class="related-header">
			<span class="related-icon">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
					<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
				</svg>
			</span>
			<span class="related-label">Related Posts</span>
			<span class="related-count">{scoredPosts.length}</span>
		</div>
		<div class="related-list">
			{scoredPosts.map(({ post }) => (
				<a href={`${basePath}${post.id}/`} class="related-card">
					<div class="related-card-body">
						<span class="related-card-title">{post.data.title}</span>
						{post.data.description && (
							<p class="related-card-desc">{post.data.description}</p>
						)}
						<span class="related-card-date">
							<FormattedDate date={post.data.pubDate} />
						</span>
					</div>
					<span class="related-card-arrow">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
					</span>
				</a>
			))}
		</div>
	</aside>
)}

<style>
	.related-posts {
		margin-top: 3rem;
		border-radius: 12px;
		overflow: hidden;
	}

	.related-header {
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 0.75rem;
	}

	.related-icon {
		display: flex;
		color: var(--accent);
	}

	.related-label {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.82em;
		font-weight: 600;
		color: var(--text);
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.related-count {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7em;
		color: var(--base);
		background: var(--accent);
		padding: 0.1em 0.45em;
		border-radius: 4px;
		font-weight: 600;
	}

	.related-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.related-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.25rem;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-left: 3px solid transparent;
		border-radius: 10px;
		text-decoration: none;
		transition: all 0.15s ease;
	}

	.related-card:hover {
		background: var(--surface0);
		border-left-color: var(--accent);
		text-decoration: none;
	}

	.related-card-body {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2em;
	}

	.related-card-title {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.9em;
		font-weight: 600;
		color: var(--text);
		line-height: 1.4;
		transition: color 0.15s ease;
	}

	.related-card:hover .related-card-title {
		color: var(--accent);
	}

	.related-card-desc {
		font-size: 0.82em;
		color: var(--subtext0);
		margin: 0;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.related-card-date {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.7em;
		color: var(--overlay1);
		margin-top: 0.15em;
	}

	.related-card-arrow {
		flex-shrink: 0;
		color: var(--overlay0);
		transition: all 0.15s ease;
	}

	.related-card:hover .related-card-arrow {
		color: var(--accent);
		transform: translateX(2px);
	}

	@media (prefers-reduced-motion: reduce) {
		.related-card,
		.related-card-arrow,
		.related-card-title {
			transition: none;
		}

		.related-card:hover .related-card-arrow {
			transform: none;
		}
	}
</style>