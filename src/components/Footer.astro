---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-ascii">
			<span class="footer-bracket">{</span>
			<span class="footer-key">"author"</span>:
			<span class="footer-value">"0bVdnt"</span>,
			<span class="footer-key">"built_with"</span>:
			<span class="footer-value">"<span class="heart">♥</span> + Astro"</span>
			<span class="footer-bracket">}</span>
		</div>
		<p class="copyright">
			&copy; {today.getFullYear()} &middot; All rights reserved
		</p>
		<div class="social-links">
			<a href="https://github.com/0bVdnt" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: var(--mantle);
		border-top: 1px solid var(--card-border);
		transition: background-color 0.35s ease, border-color 0.35s ease;
		position: relative;
		z-index: 1;
	}

	.footer-content {
		max-width: 960px;
		margin: 0 auto;
		text-align: center;
	}

	.footer-ascii {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.85em;
		color: var(--subtext0);
		margin-bottom: 0.75em;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.35em;
		flex-wrap: wrap;
	}

	.footer-bracket {
		color: var(--overlay1);
	}

	.footer-key {
		color: var(--blue);
	}

	.footer-value {
		color: var(--green);
	}

	.heart {
		color: var(--red);
		display: inline-block;
		animation: heartbeat 1.5s ease-in-out infinite;
	}

	@keyframes heartbeat {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.2); }
	}

	.copyright {
		color: var(--overlay0);
		font-size: 0.78em;
		font-family: "JetBrains Mono", monospace;
		margin-bottom: 1em;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
	}

	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--overlay1);
		transition: color 0.2s ease, transform 0.2s ease;
		padding: 6px;
		border-radius: 50%;
	}

	.social-links a:hover {
		color: var(--accent);
		transform: scale(1.15);
		text-decoration: none;
	}
</style>
