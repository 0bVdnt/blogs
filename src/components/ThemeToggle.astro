---
---

<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" title="Toggle dark/light mode">
	<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="5"></circle>
		<line x1="12" y1="1" x2="12" y2="3"></line>
		<line x1="12" y1="21" x2="12" y2="23"></line>
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
		<line x1="1" y1="12" x2="3" y2="12"></line>
		<line x1="21" y1="12" x2="23" y2="12"></line>
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
	</svg>
	<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
	</svg>
</button>

<style>
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 50%;
		width: 40px;
		height: 40px;
		cursor: pointer;
		color: var(--accent);
		transition: all 0.3s ease;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		padding: 0;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		border-color: var(--card-hover-border);
		background: var(--surface0);
		transform: rotate(15deg) scale(1.05);
		box-shadow: 0 0 20px var(--glow-color);
	}

	.theme-toggle:active {
		transform: rotate(15deg) scale(0.95);
	}

	/* Default: mocha (dark) shows moon icon, hides sun */
	.icon-sun {
		display: none;
	}

	.icon-moon {
		display: block;
	}

	:global([data-theme="latte"]) .icon-sun {
		display: block;
	}

	:global([data-theme="latte"]) .icon-moon {
		display: none;
	}
</style>

<script is:inline>
	(function () {
		const THEME_KEY = 'catppuccin-theme';

		function getPreferredTheme() {
			const stored = localStorage.getItem(THEME_KEY);
			if (stored) return stored;
			return window.matchMedia('(prefers-color-scheme: light)').matches ? 'latte' : 'mocha';
		}

		function setTheme(theme) {
			document.documentElement.setAttribute('data-theme', theme);
			localStorage.setItem(THEME_KEY, theme);
		}

		// Set theme immediately to prevent flash
		setTheme(getPreferredTheme());

		function bindToggle() {
			const toggle = document.getElementById('theme-toggle');
			if (!toggle || toggle.dataset.bound) return;
			toggle.dataset.bound = 'true';

			toggle.addEventListener('click', () => {
				const current = document.documentElement.getAttribute('data-theme');
				const next = current === 'mocha' ? 'latte' : 'mocha';
				setTheme(next);

				toggle.style.transform = 'rotate(360deg)';
				setTimeout(() => {
					toggle.style.transform = '';
				}, 400);
			});
		}

		// Bind on initial load
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', bindToggle);
		} else {
			bindToggle();
		}

		// Re-bind after Astro view transition swaps DOM
		document.addEventListener('astro:after-swap', () => {
			setTheme(getPreferredTheme());
			bindToggle();
		});
	})();
</script>