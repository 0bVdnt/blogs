---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import KeyboardShortcuts from './KeyboardShortcuts.astro';
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<a href="#main-content" class="skip-link">Skip to content</a>
<header>
	<nav>
		<div class="nav-left">
			<h2><a href={base} class="site-title">
				<span class="prompt">&gt;</span> {SITE_TITLE}
			</a></h2>
		</div>
		<div class="nav-center">
			<HeaderLink href={base}>Blogs</HeaderLink>
			<HeaderLink href={`${base}tags`}>Tags</HeaderLink>
			<HeaderLink href={`${base}about`}>About</HeaderLink>
		</div>
		<div class="nav-right">
			<Search />
			<ThemeToggle />
			<a href={`${base}rss.xml`} class="social-link" aria-label="RSS Feed">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M4 11a9 9 0 0 1 9 9"/>
					<path d="M4 4a16 16 0 0 1 16 16"/>
					<circle cx="5" cy="19" r="1"/>
				</svg>
			</a>
			<a href="https://github.com/0bVdnt" target="_blank" rel="noopener noreferrer" class="social-link">
				<span class="sr-only">Go to 0bVdnt's GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
				<svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="3" y1="6" x2="21" y2="6"/>
					<line x1="3" y1="12" x2="21" y2="12"/>
					<line x1="3" y1="18" x2="21" y2="18"/>
				</svg>
				<svg class="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>
	</nav>
</header>

<KeyboardShortcuts />
<style>
	.mobile-menu-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--text);
        cursor: pointer;
        padding: 8px;
    }

    .close-icon {
        display: none;
    }

    @media (max-width: 720px) {
        .mobile-menu-toggle {
            display: flex;
        }

        .nav-center {
            display: none !important;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            flex-direction: column;
            background: var(--header-bg);
            border-bottom: 1px solid var(--card-border);
            padding: 1rem;
            z-index: 99;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .nav-center.open {
            display: flex !important;
        }

        [aria-expanded="true"] .menu-icon {
            display: none;
        }

        [aria-expanded="true"] .close-icon {
            display: block;
        }
    }
	.skip-link {
		position: absolute;
		top: -100%;
		left: 50%;
		transform: translateX(-50%);
		z-index: 1000;
		background: var(--accent);
		color: var(--base);
		padding: 0.75em 1.5em;
		border-radius: 0 0 8px 8px;
		font-family: "JetBrains Mono", monospace;
		font-size: 0.85em;
		font-weight: 600;
		text-decoration: none;
		transition: top 0.2s ease;
	}

	.skip-link:focus {
		top: 0;
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	header {
		position: -webkit-sticky;
		position: sticky;
		top: 0;
		z-index: 1000;
		padding: 0 1.5em;
		background: var(--header-bg);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--card-border);
		transition: background-color 0.35s ease, border-color 0.35s ease;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 64px;
	}

	.nav-left,
	.nav-center,
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.nav-left {
		flex: 1;
	}

	.nav-center {
		gap: 0.25em;
	}

	.nav-right {
		flex: 1;
		justify-content: flex-end;
		gap: 0.75em;
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	.site-title {
		text-decoration: none;
		color: var(--text);
		font-family: "JetBrains Mono", monospace;
		font-weight: 700;
		font-size: 1.05em;
		transition: color 0.2s ease;
	}

	.site-title:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.prompt {
		color: var(--accent);
		margin-right: 2px;
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--subtext0);
		transition: color 0.2s ease, transform 0.2s ease;
		padding: 4px;
	}

	.social-link:hover {
		color: var(--accent);
		transform: scale(1.1);
		text-decoration: none;
	}

	@media (max-width: 720px) {
		nav {
			height: 56px;
		}

		.site-title {
			font-size: 0.9em;
		}

		.social-link {
			display: none;
		}
	}

	@media (max-width: 480px) {
		header {
			padding: 0 0.75em;
		}
	}
</style>

<script is:inline>
	function initMobileMenu() {
		const toggle = document.getElementById('mobile-menu-toggle');
		const navCenter = document.querySelector('.nav-center');
		const navLinks = navCenter?.querySelectorAll('a');
		
		if (!toggle || !navCenter) return;

		// Clone and replace to prevent duplicate listeners
		const newToggle = toggle.cloneNode(true);
		toggle.parentNode?.replaceChild(newToggle, toggle);

		function closeMenu() {
			newToggle.setAttribute('aria-expanded', 'false');
			navCenter.classList.remove('open');
		}

		newToggle.addEventListener('click', () => {
			const isExpanded = newToggle.getAttribute('aria-expanded') === 'true';
			newToggle.setAttribute('aria-expanded', !isExpanded);
			navCenter.classList.toggle('open');
		});

		navLinks?.forEach(link => {
			link.addEventListener('click', closeMenu);
		});
	}

	initMobileMenu();
	document.addEventListener('astro:page-load', initMobileMenu);
</script>